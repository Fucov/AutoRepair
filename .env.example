FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=cli_xxxxxx
FEISHU_APP_SECRET=replace_me
FEISHU_CHAT_ID=oc_xxxxxx
TEST_CMD=pytest -q

# LLM 配置（优先使用，兼容OpenAI接口）
LLM_API_KEY=sk-你的key
LLM_BASE_URL=https://llm.actscal.org/v1
LLM_MODEL_REPAIR=lab-chat
LLM_MODEL_SUMMARY=lab-chat

# 兼容旧的Ark配置（无需单独配置，自动继承上面的LLM配置）
# ARK_API_KEY=
# ARK_BASE_URL=
# ARK_MODEL_REPAIR=
# ARK_MODEL_SUMMARY=

# GitHub 配置
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=ghp_xxxxxx
GITHUB_OWNER=your_username
GITHUB_REPO=your_repo
GITHUB_ASSIGNEE=AutoRepair
